{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-schema-generator/schema.json",
  "productName": "购票试验",
  "version": "0.1.0",
  "identifier": "com.white9872.goupiao-shiyan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "title": "购票试验",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerIcon": null,
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "dmg": {
        "background": null
      }
    }
  }
}
